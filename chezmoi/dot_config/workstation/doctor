#!/usr/bin/env bash
set -u

usage() {
  cat <<'EOF'
usage: doctor [--phase foundation|shell|wezterm|quake|all] [--help]

Later phases are documented in PLAN.md but are not implemented yet.
EOF
}

phase=all
while [ "$#" -gt 0 ]; do
  case "$1" in
    --phase)
      [ "$#" -ge 2 ] || { printf 'doctor: --phase requires a value\n' >&2; exit 2; }
      phase=$2
      shift 2
      ;;
    --phase=*)
      phase=${1#--phase=}
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'doctor: unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

case "$phase" in
  foundation|shell|wezterm|quake|all) ;;
  neovim|yazi|rider|project|agents|models)
    printf '[fail] %-24s %s\n' "phase $phase" 'not implemented yet'
    exit 2
    ;;
  *)
    printf 'doctor: unknown phase: %s\n' "$phase" >&2
    exit 2
    ;;
esac

config_dir=${XDG_CONFIG_HOME:-$HOME/.config}/workstation
if [ -r "$config_dir/platform.sh" ]; then
  # shellcheck source=platform.sh
  . "$config_dir/platform.sh"
else
  script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
  # shellcheck source=platform.sh
  . "$script_dir/platform.sh"
fi

if [ -r "$config_dir/functions.sh" ]; then
  # shellcheck source=functions.sh
  . "$config_dir/functions.sh"
else
  script_dir=${script_dir:-$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)}
  # shellcheck source=functions.sh
  . "$script_dir/functions.sh"
fi

if command -v workstation_load_env >/dev/null 2>&1; then
  workstation_load_env
elif [ -z "${WORKSTATION_REPO_ROOT:-}" ] && [ -r "$config_dir/env.sh" ]; then
  # shellcheck source=env.sh
  . "$config_dir/env.sh"
fi

failures=0
warnings=0

ok() { printf '[ok]   %-24s %s\n' "$1" "$2"; }
warn() { warnings=$((warnings + 1)); printf '[warn] %-24s %s\n' "$1" "$2"; }
fail() { failures=$((failures + 1)); printf '[fail] %-24s %s\n' "$1" "$2"; }

version_of() {
  "$1" --version 2>/dev/null | head -n 1
}

require_command() {
  if command -v "$1" >/dev/null 2>&1; then
    ok "$1" "$(version_of "$1")"
  else
    fail "$1" 'not found'
  fi
}

optional_command() {
  if command -v "$1" >/dev/null 2>&1; then
    ok "$1" "$(version_of "$1")"
  else
    warn "$1" 'optional; not found'
  fi
}

find_command() {
  local candidate
  for candidate in "$@"; do
    if command -v "$candidate" >/dev/null 2>&1; then
      command -v "$candidate"
      return 0
    fi
  done
  return 1
}

find_windows_file() {
  local candidate
  for candidate in "$@"; do
    if [ -x "$candidate" ] || [ -r "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

repo_root() {
  if [ -n "${WORKSTATION_REPO_ROOT:-}" ]; then
    printf '%s\n' "$WORKSTATION_REPO_ROOT"
    return 0
  fi

  local root
  root=$(git rev-parse --show-toplevel 2>/dev/null || true)
  if [ -n "$root" ] && [ -r "$root/PLAN.md" ]; then
    printf '%s\n' "$root"
    return 0
  fi

  root=$PWD
  while [ "$root" != "/" ] && [ -n "$root" ]; do
    if [ -r "$root/PLAN.md" ] && [ -r "$root/README.md" ]; then
      printf '%s\n' "$root"
      return 0
    fi
    root=$(dirname -- "$root")
  done

  CDPATH= cd -- "$(dirname -- "$0")/../../.." && pwd
}

check_foundation() {
  ok 'operating system' "$WORKSTATION_OS"
  ok 'architecture' "$(uname -m 2>/dev/null || printf unknown)"
  ok 'shell' "${SHELL:-${COMSPEC:-unknown}}"
  if [ -n "${BASH_VERSION:-}" ]; then ok 'bash' "$BASH_VERSION"; else fail 'bash' 'doctor must run under Bash'; fi
  require_command git

  local root
  root=$(repo_root)
  [ -r "$root/README.md" ] && ok 'README.md' 'present' || fail 'README.md' 'missing'
  [ -r "$root/PLAN.md" ] && ok 'PLAN.md' 'present' || fail 'PLAN.md' 'missing'
  [ -r "$root/AGENTS.md" ] && ok 'AGENTS.md' 'present' || fail 'AGENTS.md' 'missing'
  [ -r "$root/docs/architecture.md" ] && ok 'architecture doc' 'present' || fail 'architecture doc' 'missing'
  [ -r "$root/docs/provisioning.md" ] && ok 'provisioning doc' 'present' || fail 'provisioning doc' 'missing'
  [ -r "$root/docs/shell.md" ] && ok 'shell doc' 'present' || fail 'shell doc' 'missing'
  [ -r "$root/config/workstation.example.toml" ] && ok 'workstation config' 'example present' || fail 'workstation config' 'missing'
  [ -r "$root/config/agents.example.toml" ] && ok 'agents config' 'example present' || fail 'agents config' 'missing'
  [ -r "$root/config/models.example.toml" ] && ok 'models config' 'example present' || fail 'models config' 'missing'
}

check_shell() {
  check_foundation

  if [ "$WORKSTATION_OS" = windows ]; then
    if workstation_is_git_bash; then ok 'Git Bash session' 'detected'; else fail 'Git Bash session' 'not detected; run from Git for Windows Bash'; fi
    local git_bash
    git_bash=$(workstation_git_bash_path 2>/dev/null || true)
    [ -n "$git_bash" ] && ok 'Git Bash path' "$git_bash" || fail 'Git Bash path' 'not detected'
  elif [ "$WORKSTATION_OS" = ubuntu ]; then
    ok 'session type' "$(workstation_session_type)"
    if command -v gnome-shell >/dev/null 2>&1; then ok 'GNOME Shell' "$(gnome-shell --version 2>/dev/null)"; else warn 'GNOME Shell' 'not detected'; fi
  elif [ "$WORKSTATION_OS" = macos ]; then
    optional_command brew
  fi

  local missing=''
  missing=$(workstation_check_unix_commands || true)
  if [ -z "$missing" ]; then
    ok 'Unix-style commands' 'required commands available'
  else
    fail 'Unix-style commands' "missing: $(printf '%s' "$missing" | tr '\n' ' ')"
  fi

  optional_command rg
  optional_command fd
  optional_command fdfind
  optional_command jq
  optional_command fzf

  if [ -r "${XDG_CONFIG_HOME:-$HOME/.config}/workstation/platform.sh" ]; then
    ok 'managed shell config' 'platform.sh readable'
  else
    warn 'managed shell config' 'not applied with chezmoi yet'
  fi

  warn 'future helpers' 'project, y, nv, rider, wt-*, agent, and agent-notify are stubs'
}

check_wezterm() {
  check_shell

  local root wezterm_cmd config_path
  root=$(repo_root)
  config_path="${XDG_CONFIG_HOME:-$HOME/.config}/wezterm/wezterm.lua"
  if [ ! -r "$config_path" ] && [ -r "$root/chezmoi/dot_config/wezterm/wezterm.lua" ]; then
    config_path="$root/chezmoi/dot_config/wezterm/wezterm.lua"
  fi

  wezterm_cmd=$(find_command wezterm wezterm.exe || true)
  if [ -n "$wezterm_cmd" ]; then
    ok 'wezterm' "$("$wezterm_cmd" --version 2>/dev/null | head -n 1)"
  else
    fail 'wezterm' 'not found'
  fi

  if [ -r "$config_path" ]; then
    ok 'WezTerm config' "$config_path"
    if grep -q 'intentionally not implemented' "$config_path"; then
      fail 'WezTerm config' 'placeholder failure is still present'
    fi
  else
    fail 'WezTerm config' 'wezterm.lua missing'
  fi

  if [ -n "$wezterm_cmd" ] && [ -r "$config_path" ]; then
    if "$wezterm_cmd" --config-file "$config_path" show-keys --lua >/dev/null 2>&1; then
      ok 'WezTerm config load' 'show-keys --lua succeeded'
    else
      fail 'WezTerm config load' 'show-keys --lua failed'
    fi
  fi

  if [ "$phase" = wezterm ]; then
    warn 'Quake mode' 'deferred to Phase 3'
  fi
  warn 'Yazi/Neovim bindings' 'bindings call helper stubs until Phases 4 and 5'
}

check_quake() {
  check_wezterm

  local root adapter autohotkey_cmd
  root=$(repo_root)
  adapter="$root/platform/windows/quake-toggle.ahk"

  if [ "$WORKSTATION_OS" = windows ]; then
    autohotkey_cmd=$(find_command AutoHotkey64.exe AutoHotkey.exe || true)
    if [ -z "$autohotkey_cmd" ]; then
      autohotkey_cmd=$(find_windows_file \
        '/c/Program Files/AutoHotkey/v2/AutoHotkey64.exe' \
        '/c/Program Files/AutoHotkey/AutoHotkey64.exe' \
        "$HOME/AppData/Local/Programs/AutoHotkey/v2/AutoHotkey64.exe" \
        "$HOME/AppData/Local/Programs/AutoHotkey/AutoHotkey64.exe" || true)
    fi
    if [ -n "$autohotkey_cmd" ]; then
      ok 'AutoHotkey' "$autohotkey_cmd"
    else
      fail 'AutoHotkey' 'not found; install AutoHotkey v2'
    fi

    [ -r "$adapter" ] && ok 'Quake adapter' "$adapter" || fail 'Quake adapter' 'missing'
    if [ -r "$adapter" ]; then
      grep -q '#Requires AutoHotkey v2.0' "$adapter" && ok 'Quake adapter version' 'requires AutoHotkey v2' || fail 'Quake adapter version' 'missing AutoHotkey v2 requirement'
      grep -Fq 'Hotkey("^``", ToggleQuake)' "$adapter" && ok 'Quake hotkey' 'Ctrl+` registered' || fail 'Quake hotkey' 'Ctrl+` registration missing'
      grep -q 'WinMinimize' "$adapter" && ok 'Quake dismiss behavior' 'minimize fallback configured' || fail 'Quake dismiss behavior' 'missing'
      grep -q 'WinMove' "$adapter" && ok 'Quake placement behavior' 'configured' || fail 'Quake placement behavior' 'missing'
      if [ -n "$autohotkey_cmd" ]; then
        local native_adapter
        native_adapter=$adapter
        if command -v cygpath >/dev/null 2>&1; then
          native_adapter=$(cygpath -aw "$adapter")
        fi
        if "$autohotkey_cmd" //Validate "$native_adapter" >/dev/null 2>&1; then
          ok 'Quake adapter syntax' 'AutoHotkey validation passed'
        else
          fail 'Quake adapter syntax' 'AutoHotkey validation failed'
        fi
      fi
    fi

    local startup_shortcut
    if [ -n "${APPDATA:-}" ]; then
      startup_shortcut=$APPDATA
      if command -v cygpath >/dev/null 2>&1; then
        startup_shortcut=$(cygpath -u "$APPDATA")
      fi
      startup_shortcut="$startup_shortcut/Microsoft/Windows/Start Menu/Programs/Startup/cross-platform-workstation-quake.lnk"
      if [ -r "$startup_shortcut" ]; then
        ok 'Quake startup' "$startup_shortcut"
      else
        fail 'Quake startup' 'Startup shortcut missing; rerun setup.ps1 -Phase quake'
      fi
    else
      warn 'Quake startup' 'APPDATA not set; could not check Startup shortcut'
    fi

    warn 'Quake manual validation' 'focused-monitor placement and multi-monitor movement require manual GUI validation'
  else
    warn 'Quake adapter' 'implemented only for Windows; macOS/Ubuntu remain documented stubs'
  fi
}

case "$phase" in
  foundation) check_foundation ;;
  shell) check_shell ;;
  wezterm) check_wezterm ;;
  quake|all) check_quake ;;
esac

if [ "$failures" -gt 0 ]; then
  printf '\n%d required check(s) failed; %d warning(s).\n' "$failures" "$warnings" >&2
  exit 1
fi

printf '\nRequired checks passed; %d warning(s).\n' "$warnings"
